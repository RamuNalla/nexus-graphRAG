# ─────────────────────────────────────────────────────────────
# Nexus GraphRAG — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Groq API Key (required)
# Get a FREE key at: https://console.groq.com
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# Neo4j connection (defaults match docker-compose.yml — change only if needed)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123

# Qdrant connection (defaults match docker-compose.yml)
QDRANT_URL=http://localhost:6333

# ── Optional tuning ──────────────────────────────────────────
# Number of PDF pages to send to the LLM.
# Free Groq tier: keep ≤ 15.  Paid / local LLM: set higher.
MAX_PAGES=10
